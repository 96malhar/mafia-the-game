# Build artifacts
bin/
dist/
# Bare `go build ./cmd/server` drops a binary named after the package dir
# in the repo root; ignore it (real builds go to bin/ via `task build`).
/server
*.exe
*.test
*.prof

# Test & coverage output
coverage.out
coverage.html
*.out

# Go workspace files (we don't commit these; each dev has their own)
go.work
go.work.sum

# Dependency vendoring (we use modules, not vendor/)
vendor/

# Environment & local config
.env
.env.local
*.local

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# OS detritus
.DS_Store
Thumbs.db

# Logs & runtime data
*.log
tmp/

# Task runner local cache
.task/

# Node (frontend dev test deps only — runtime frontend stays no-build)
node_modules/
