{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Your Fly-managed Prometheus data source (e.g. 'Prometheus on Fly').",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mafia"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Mafia — App Metrics",
  "uid": "mafia-app-metrics",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active players",
      "description": "players_connected — players currently connected and seated in a room (one per attached seat). Ignores never-joined sockets and is refresh-stable, unlike a raw connection count. Thresholds track the ~800/1000 connection caps (≈ one connection per player).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 800 },
            { "color": "red", "value": 1000 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(players_connected)", "legendFormat": "players" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Games in progress",
      "description": "game_in_progress — games currently being played (started, not yet ended/abandoned).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(game_in_progress)", "legendFormat": "games" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active rooms",
      "description": "room_active — rooms held in memory (lobbies + in-progress + finished-awaiting-reset). Thresholds reflect DefaultMaxRooms (250).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 200 },
            { "color": "red", "value": 250 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(room_active)", "legendFormat": "rooms" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Room panics (in range)",
      "description": "room_panic_total — panics recovered in a room goroutine within the dashboard time range. Each is a bug to investigate; this should normally be 0.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.5 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(increase(room_panic_total[$__range]))", "legendFormat": "panics" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Live activity",
      "description": "Players, games in progress, and active rooms over time.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 12, "showPoints": "auto", "lineWidth": 2, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(players_connected)", "legendFormat": "players" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(game_in_progress)", "legendFormat": "games in progress" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(room_active)", "legendFormat": "active rooms" }
      ]
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "Wins by faction (in range)",
      "description": "sum by (winner) (increase(game_completed_total[range])) — completed games split by winning faction.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "pie",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "values": ["value"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (winner) (increase(game_completed_total[$__range]))", "legendFormat": "{{winner}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Games started / completed (cumulative)",
      "description": "Raw counters since the process started. NOTE: this app is single-instance/in-memory, so the counters reset to 0 on every deploy or restart (a sawtooth). For a window count that survives restarts, see the 'completed (in range)' stat or use increase().",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 8, "showPoints": "auto", "lineWidth": 2, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(game_started_total)", "legendFormat": "started (cumulative)" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(game_completed_total)", "legendFormat": "completed (cumulative)" }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Completion rate (in range)",
      "description": "completed / started over the dashboard range — what fraction of started games actually finished (vs abandoned). NaN when no games started.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "none", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green", "value": 0.8 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(increase(game_completed_total[$__range])) / sum(increase(game_started_total[$__range]))", "legendFormat": "completion rate" }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Games completed (in range)",
      "description": "sum(increase(game_completed_total[range])) — games finished within the dashboard range. Reset-aware (survives deploys).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(increase(game_completed_total[$__range]))", "legendFormat": "completed" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Command rejections by code",
      "description": "rate(game_command_rejected_total) by wire error code — engine commands/joins rejected (wrong phase, duplicate name, forbidden, lobby full, ...). A spike can indicate a client bug or abuse.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "auto", "lineWidth": 1, "spanNulls": true, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (code) (rate(game_command_rejected_total[$__rate_interval]))", "legendFormat": "{{code}}" }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "WebSocket frame rejections by reason",
      "description": "rate(ws_message_rejected_total) by reason — malformed/undecodable/unknown inbound frames at the transport layer. The main server-side signal for bad or abusive traffic (these aren't logged).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10, "showPoints": "auto", "lineWidth": 1, "spanNulls": true, "stacking": { "mode": "normal", "group": "A" } }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum by (reason) (rate(ws_message_rejected_total[$__rate_interval]))", "legendFormat": "{{reason}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Game duration percentiles (p25 / p50 / p99)",
      "description": "histogram_quantile over game_duration_seconds_bucket — wall-clock length of completed games (StartGame → win). Percentiles are derived from the histogram buckets, so resolution is bounded by the bucket boundaries (15s…2h). Only finished games count; abandoned games are absent.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 28 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 8, "showPoints": "auto", "lineWidth": 2, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.25, sum(rate(game_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p25" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.50, sum(rate(game_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.99, sum(rate(game_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Median game duration (in range)",
      "description": "p50 of completed-game duration over the dashboard range — histogram_quantile(0.5, ...[$__range]).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "purple" } },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.5, sum(rate(game_duration_seconds_bucket[$__range])) by (le))", "legendFormat": "p50" }
      ]
    }
  ]
}
